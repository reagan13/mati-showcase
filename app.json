{
  "expo": {
    "name": "mati-ecom",
    "slug": "mati-ecom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/farming_lion.png",
    "scheme": "matiecom",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/farming_lion.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/farming_lion.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/farming_lion.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B1120",
          "dark": {
            "backgroundColor": "#0B1120"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
